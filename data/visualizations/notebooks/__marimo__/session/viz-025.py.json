      "id": "BYtC",
      "code_hash": "ed6dcea6658a4aa49c2340fda71af04b",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Venezuela's inflation peaked at 65,374% in 2018 before collapsing under dollarization</li>\n<li>Argentina surged to 220% in 2024 before IMF projects a dramatic decline under Milei's reforms</li>\n<li>Turkey tamed inflation to single digits by 2004 only to see it resurge past 72% in 2022</li>\n<li>Japan spent over two decades in deflation, only recently seeing positive inflation</li>\n</ul></span>"
          }
        }
      ],
