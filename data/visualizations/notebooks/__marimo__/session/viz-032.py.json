      "id": "BYtC",
      "code_hash": "f07a6ba3fd6b3e6380951d12c84aa680",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Guinea reduced its out-of-school rate from 75.8% to 14.7%, one of the largest improvements</li>\n<li>India went from 23.4% to just 0.1%, essentially achieving universal primary enrollment</li>\n<li>Mozambique dropped from 51.7% to 1.0%, an extraordinary transformation</li>\n<li>South Sudan is the only country shown where the rate worsened, from 55.3% to 64.7%</li>\n</ul></span>"
          }
        }
      ],
