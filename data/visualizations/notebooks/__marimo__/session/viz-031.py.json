      "id": "BYtC",
      "code_hash": "09042ce536810f7bec9bc41d8dc334df",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Sudan's IDP population exploded from 3.5M to 11.6M between 2022 and 2024 following civil war</li>\n<li>Syria has maintained ~7M internally displaced since 2013, a persistent crisis</li>\n<li>Colombia's long-running displacement peaked near 8.3M in 2020</li>\n<li>The total for just these 10 countries exceeds 50 million people displaced within their own borders</li>\n</ul></span>"
          }
        }
      ],
