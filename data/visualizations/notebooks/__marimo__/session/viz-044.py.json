      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Rwanda leads the world with 61% women in parliament, having surged from 17% after the 1994 genocide</li>\n<li>Japan barely moved from 4.6% to 15.7% over 27 years, one of the slowest improvements among democracies</li>\n<li>Mexico jumped from 14% to over 50% after adopting gender parity quotas in 2014</li>\n<li>Saudi Arabia went from 0% to 20% after women were first allowed to serve in the Shura Council in 2013</li>\n</ul></span>"
          }
        }
      ],
      "console": []
