      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Kuwait runs the largest fiscal surplus at 26.8% of GDP, driven entirely by oil revenues</li>\n<li>China (-8.6%) and Brazil (-8.4%) run the largest deficits among major economies</li>\n<li>The United States deficit of -7.4% places it among the world's biggest borrowers</li>\n<li>Norway (+12.7%) channels oil wealth into its sovereign wealth fund, maintaining strong surpluses</li>\n</ul></span>"
          }
        }
      ],
