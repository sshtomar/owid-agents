    {
      "id": "BYtC",
      "code_hash": "b50e10323e7f6d2041d06652054f2019",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>North Korea climbed from 56% in 2000 to 99% by 2021</li>\n<li>Brazil and Romania both fell from near-universal coverage (98-99%) to below 80%</li>\n<li>India rose steadily from 59% to 91%, crossing the WHO 90% target threshold by 2023</li>\n<li>Yemen and Papua New Guinea remain far below the 90% target with no sign of recovery</li>\n</ul></span>"
          }
        }
      ],
