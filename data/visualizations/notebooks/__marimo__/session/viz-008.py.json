      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Chile saw the largest gain: from 31% to 52.8%, a 21.8 percentage point increase</li>\n<li>China and Ethiopia both declined -- from over 73% to under 60% -- as economies restructured</li>\n<li>Iran started at 9.6% in 1990 and rose only to 14.1% by 2024</li>\n<li>South Korea, Japan, and Germany all converged near 55-57%, from very different starting points</li>\n</ul></span>"
          }
        }
      ],
      "console": []
