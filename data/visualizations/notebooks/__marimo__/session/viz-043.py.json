      "id": "BYtC",
      "code_hash": "c5972420e06c7ece1c0f18dbc764061b",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Cameroon leads at 54.8 ug/m3, nearly 11 times the WHO guideline of 5 ug/m3</li>\n<li>Bangladesh (50.1) and Niger (50.7) round out the top three, all in the darkest severity tier</li>\n<li>Even wealthy nations like Germany (11.2), France (10.5), and Japan (10.8) exceed the guideline by 2x</li>\n<li>Canada (5.2) is the only country approaching compliance with WHO's annual mean target</li>\n</ul></span>"
          }
        }
      ],
