          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"every-breath-you-take\">Every Breath You Take</h1>\n<span class=\"paragraph\">Mean annual PM2.5 air pollution concentration (ug/m3) for 30 countries in 2019. WHO guideline is 5 ug/m3. Only Canada comes close. Most of South Asia and Sub-Saharan Africa exceeds the guideline by 5-10x.</span></span>"
          }
        }
      ],
