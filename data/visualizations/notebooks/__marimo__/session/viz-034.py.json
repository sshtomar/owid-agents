      "id": "BYtC",
      "code_hash": "31b6e1057f86c69f4cf439f3097fda23",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Switzerland leads at ~130% of GDP, the highest household debt ratio among major economies</li>\n<li>Ireland's household debt peaked at ~110% during the Celtic Tiger era, then crashed after 2008</li>\n<li>Spain and the UK both show dramatic deleveraging after the 2008 crisis</li>\n<li>South Korea's household debt has risen steadily to over 100%, bucking the post-crisis deleveraging trend</li>\n</ul></span>"
          }
        }
      ],
