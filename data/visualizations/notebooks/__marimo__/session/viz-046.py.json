    {
      "id": "BYtC",
      "code_hash": "48081f924a8fc94fcf93c11e64d95226",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Bangladesh achieved the largest absolute reduction: from 70.9% to 23.6%, lifting millions of children out of chronic malnutrition</li>\n<li>Cambodia dropped from 58.6% to 21.9%, one of Southeast Asia's greatest nutrition success stories</li>\n<li>Guatemala's rate barely moved from 62.2% to 46.0% over three decades despite being a middle-income country</li>\n<li>India reduced stunting from 62.7% to 35.5%, but with 1.4 billion people, millions of children are still affected</li>\n</ul></span>"
          }
        }
      ],
      "console": []
    }
