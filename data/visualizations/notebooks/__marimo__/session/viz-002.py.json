      "id": "BYtC",
      "code_hash": "35c25f91c30aaf7ced613298771b8b56",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Afghanistan's under-5 mortality fell from 353 to 56 per 1,000 live births</li>\n<li>Bangladesh dropped from 262 to 31 -- a 10x improvement</li>\n<li>Kenya shows a striking reversal in the 1990s (HIV/AIDS crisis) before resuming decline</li>\n<li>Japan reached 2 per 1,000 -- nearly eliminating child mortality entirely</li>\n</ul></span>"
          }
        }
      ],
