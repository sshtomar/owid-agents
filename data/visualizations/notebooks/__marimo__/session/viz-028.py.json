          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Israel increased from 6.37% to 8.78% of GDP on defense following regional conflicts</li>\n<li>Algeria nearly tripled its military spending share from 3.41% to 7.97%</li>\n<li>Estonia doubled from 1.66% to 3.37%, leading NATO's rearmament push</li>\n<li>Ethiopia made the sharpest cut, from 3.76% to just 0.65%</li>\n</ul></span>"
          }
        }
