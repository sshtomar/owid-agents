      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Kuwait withdraws 3,850% of its renewable freshwater, entirely dependent on desalination</li>\n<li>Egypt (141%) and Algeria (98%) are the only African nations in critical or near-critical territory</li>\n<li>India at 60% and Israel at 56% approach high-stress thresholds despite very different economic contexts</li>\n<li>Most European countries fall well below the 25% moderate-stress threshold</li>\n</ul></span>"
          }
        }
      ],
