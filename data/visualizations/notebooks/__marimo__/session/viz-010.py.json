      "id": "BYtC",
      "code_hash": "dcf39c46baef33afa724fdfe13720fdd",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Iceland and Norway already led in 2004 with ~58% renewable share and have since exceeded 77-79%</li>\n<li>Denmark made the largest gain among major EU members, nearly tripling from 14.8% to 46.5%</li>\n<li>Greece, Germany, and Spain started below 10% in 2004 and have all crossed 22-25% by 2024</li>\n<li>Sweden and Finland now derive over 50% and 62% of gross final energy from renewables respectively</li>\n</ul></span>"
          }
        }
      ],
      "console": []
