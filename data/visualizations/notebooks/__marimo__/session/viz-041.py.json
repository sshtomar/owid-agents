    {
      "id": "BYtC",
      "code_hash": "a8a2fbe6b231bfbaf8c12ea9979bc1df",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Luxembourg cut emissions from 33.4 to 11.2 tonnes per capita, a 66% reduction -- the steepest in the EU</li>\n<li>Sweden has the lowest emissions at 4.5 tonnes, less than half of Germany's 7.8</li>\n<li>Poland's trajectory is the flattest, declining only 27% from 12.5 to 9.1 -- still heavily dependent on coal</li>\n<li>Ireland bucked the trend by rising from 13.2 to 18.3 during the Celtic Tiger boom before falling back to 10.0</li>\n</ul></span>"
          }
        }
      ],
      "console": []
