      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Spain reduced its gap most dramatically: from 20.2% to 7.3%, a 13 percentage point improvement</li>\n<li>Estonia remains the EU's widest gap despite falling from 29.8% to 18.8%</li>\n<li>Luxembourg is the only EU country where the gap has effectively closed: women now earn 0.8% more</li>\n<li>Three countries -- Slovenia, Croatia, and Italy -- saw their gap widen slightly</li>\n</ul></span>"
          }
        }
      ],
      "console": []
