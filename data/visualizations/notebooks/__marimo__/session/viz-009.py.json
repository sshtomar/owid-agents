    {
      "id": "BYtC",
      "code_hash": "3f25a6ac3bd26955427fd67e6a77d078",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>China's emissions tripled from ~3,200 Mt in 2001 to over 10,500 Mt in 2021, overtaking the United States around 2006</li>\n<li>The United States has fallen steadily from a peak of ~5,700 Mt in 2005 to ~4,550 Mt in 2021, a 20% reduction</li>\n<li>India is the only top-10 emitter still on a steep upward trajectory, more than doubling from 1,000 Mt to 2,500 Mt</li>\n<li>Germany cut emissions by nearly 25% over the period, the sharpest decline among large economies shown</li>\n</ul></span>"
          }
        }
      ],
