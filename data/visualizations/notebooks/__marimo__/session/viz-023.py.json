    {
      "id": "BYtC",
      "code_hash": "10b6fc6ab1e9ffe64f98a5b71de7763d",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Japan's debt peaked at 258% of GDP in 2020 and remains the highest among major economies even after declining to 236%</li>\n<li>China's debt trajectory is the steepest, projected to cross 100% of GDP by 2026 from just 23% in 2000</li>\n<li>The COVID-19 pandemic caused visible debt spikes across all countries in 2020, adding 15-25 percentage points</li>\n<li>Germany stands out as the only major economy that meaningfully reduced its debt ratio from 2010-2019</li>\n</ul></span>"
          }
        }
      ],
