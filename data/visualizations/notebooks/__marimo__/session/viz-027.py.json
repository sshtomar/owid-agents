      "id": "BYtC",
      "code_hash": "9f1410b4f27b64b0ae170507956f8441",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>France maintains the world's highest nuclear share at ~65%, though down from 77% in 2005</li>\n<li>Japan's nuclear share crashed from 25% to near zero after Fukushima and has only partially recovered to ~8%</li>\n<li>Germany completed its nuclear phase-out, dropping from 30% to 0% by 2023</li>\n<li>China is the only country rapidly expanding nuclear, growing from 1% to over 5%</li>\n</ul></span>"
          }
        }
      ],
