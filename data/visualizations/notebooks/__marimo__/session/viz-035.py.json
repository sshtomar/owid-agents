      "id": "BYtC",
      "code_hash": "3c01964e67804741f4b3d6651d61c535",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Norway's current account surplus peaked at 29.6% of GDP in 2022, driven by energy exports</li>\n<li>The United States has run persistent deficits of 2-6% for over two decades</li>\n<li>China's surplus moderated from nearly 10% in 2007 to 2-3%, reducing global imbalances</li>\n<li>Germany's large surplus (peaked at ~9% in 2016) has been a source of European economic tension</li>\n</ul></span>"
          }
        }
      ],
