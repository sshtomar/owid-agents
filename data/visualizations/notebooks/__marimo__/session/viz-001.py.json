      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>China gained 44.5 years of life expectancy, the largest absolute gain of any country shown</li>\n<li>Iran, Afghanistan, and Bangladesh each gained more than 30 years</li>\n<li>Rich nations in 1960 gained 11-16 years; poor nations gained 15-44 years, showing convergence</li>\n<li>Chad and Central African Republic remain below 58 years despite gains</li>\n</ul></span>"
          }
        }
      ],
