          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>Kazakhstan went from 0.7% to 93.4% internet adoption -- a 133x increase</li>\n<li>China went from 1.8% to 92% -- connecting over a billion people</li>\n<li>Albania jumped from 0.1% to 83.1%, one of the largest relative gains</li>\n<li>Kenya and Bangladesh remain below 50%, showing the divide persists in parts of South Asia and Africa</li>\n</ul></span>"
          }
        }
      ],
      "console": []
