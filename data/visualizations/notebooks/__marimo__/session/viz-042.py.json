      "id": "BYtC",
      "code_hash": "0393ae60cde1075adb41f34ed8d14f49",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>South Korea cut NCD mortality from 23.2% to 9.2%, the most dramatic improvement in the dataset</li>\n<li>Russia's trajectory reversed: NCD mortality rose from 24.4% to 28.0% before recent improvements</li>\n<li>Egypt is one of the few countries where NCD mortality worsened, rising from 29.5% to 30.6%</li>\n<li>Germany and the USA both achieved significant reductions, but the USA's 2020 data reflects COVID disruption</li>\n</ul></span>"
          }
        }
      ],
      "console": []
