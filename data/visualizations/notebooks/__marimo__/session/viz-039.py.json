    {
      "id": "BYtC",
      "code_hash": "d4eab61bfd0f407bdcd11847c4905211",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>South Africa's TB rate peaked at 1,230 per 100k in 2010 driven by HIV co-infection, then fell 68% to 389 by 2024</li>\n<li>The Philippines is the only high-burden country where incidence is rising, from 590 to 627</li>\n<li>Nigeria's rate has been frozen at exactly 219 per 100,000 for 18 consecutive years of reporting</li>\n<li>Ethiopia achieved a 65% reduction from 462 to 163, one of Africa's greatest TB success stories</li>\n</ul></span>"
          }
        }
      ],
