    {
      "id": "BYtC",
      "code_hash": "c93db83161b06929599d8c9108936450",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"key-insights\">Key Insights</h2>\n<ul>\n<li>South Korea fell from 4.5 births per woman in 1970 to 0.72 in 2023 -- the lowest in the world</li>\n<li>Iran's drop was the fastest: from 7.5 to 1.7, mostly in a single decade (1985-1995)</li>\n<li>China's one-child policy shows as a sharp cliff from 6.6 in 1965 to 3.6 in 1975</li>\n<li>Ethiopia remains the only country shown still above 3, but is falling rapidly</li>\n</ul></span>"
          }
        }
      ],
